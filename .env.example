# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hookdrop

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-key-here
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-key-here
FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Email
RESEND_API_KEY=your_resend_api_key_here

# App
NODE_ENV=development
INGESTION_PORT=3002
API_PORT=3000
FRONTEND_URL=http://localhost:3004

SENTRY_DSN=your_sentry_dsn_here
PAYMENT_MODE=test
ADMIN_EMAIL=your-email-here
